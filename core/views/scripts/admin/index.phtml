/**
 * Admin dashboard — a Muuri masonry grid of module-registered widgets (Tiger_Dashboard). The shell
 * owns the card chrome (drag handle, collapse, sizing) and the layout; each widget owns only its body.
 * Up to 4 responsive columns by width; drag to rearrange and collapse state persist per-user (option
 * tier) over /api. Empty until a module registers a widget — nothing is hard-coded here.
 *
 * "Customize" (top-right) opens a modal to switch widgets on/off (WP "Screen Options" style). A hidden
 * widget renders here as a header-only shell (d-none, its body NOT rendered — no work done), kept out of
 * the Muuri grid; switching it back on fetches the body via /api (Dashboard::widgetBody) and drops the
 * card into the grid live — no page reload. The hidden set persists per-user (tiger.dashboard.prefs).
 */
$widgets = isset($this->widgets) && is_array($this->widgets) ? $this->widgets : [];
$tr = Zend_Registry::isRegistered('Zend_Translate') ? Zend_Registry::get('Zend_Translate') : null;
$t  = function ($s) use ($tr) { return $tr ? $tr->translate($s) : $s; };
?>
<header class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-secondary mb-0 small">Welcome to the Tiger admin.</p>
    </div>
    <?php if (!empty($widgets)): ?>
    <button type="button" class="btn btn-sm btn-outline-secondary" id="dash-customize">
        <i class="fa-solid fa-sliders me-1"></i>Customize
    </button>
    <?php endif; ?>
</header>

<?php if (empty($widgets)): ?>
    <div class="text-center text-body-secondary py-5">
        <i class="fa-regular fa-window-restore fa-2x mb-3 d-block"></i>
        <p class="mb-1 fw-semibold text-body">No dashboard widgets yet</p>
        <p class="mb-0">Modules that provide a dashboard widget will appear here automatically once they're active.</p>
    </div>
<?php else: ?>
    <div class="dash-grid" id="dash-grid">
        <?php foreach ($widgets as $w):
            $id     = htmlspecialchars($w['id'], ENT_QUOTES);
            $title  = htmlspecialchars($t($w['title']), ENT_QUOTES);
            $icon   = htmlspecialchars($w['icon'] ?: 'fa-square', ENT_QUOTES);
