<?php
/**
 * Set-a-new-password form (reached from the emailed reset link). The token (cid +
 * code) rides in hidden fields; AJAX POST to /auth/reset redeems it and sets the
 * password, then sends the user to sign in.
 */
$cid  = $this->escape($this->cid ?? '');
$code = $this->escape($this->code ?? '');
?>
<div class="tiger-auth-brand">
    <span class="tiger-auth-mark"><i class="fa-solid fa-lock"></i></span>
    <h1 class="h4 mb-1">Set a new password</h1>
    <p class="text-body-secondary small mb-0">Choose a strong password you don't use elsewhere.</p>
</div>

<div id="reset-feedback"></div>

<form id="reset-form" novalidate>
    <input type="hidden" name="cid" value="<?= $cid ?>">
    <input type="hidden" name="code" value="<?= $code ?>">
    <div class="mb-3">
        <label class="form-label" for="reset-password">New password</label>
        <input type="password" class="form-control form-control-lg" id="reset-password" name="password"
               autocomplete="new-password" autofocus required>
    </div>
    <div class="mb-3">
        <label class="form-label" for="reset-confirm">Confirm password</label>
        <input type="password" class="form-control form-control-lg" id="reset-confirm" name="confirm"
               autocomplete="new-password" required>
    </div>
    <?php $rc = $this->formRecaptcha(); if ($rc): ?>
    <div class="mb-3 d-flex justify-content-center"><?= $rc ?></div>
    <?php endif; ?>
    <div class="d-grid mb-2">
        <button type="submit" id="reset-submit" class="btn btn-primary btn-lg">Set new password</button>
    </div>
</form>

<div class="tiger-auth-foot">
    <a href="/auth/login" class="small text-decoration-none">Back to sign in</a>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('reset-form');
    var fb   = document.getElementById('reset-feedback');
    var btn  = document.getElementById('reset-submit');

    function fail(msg) {
        fb.innerHTML = '';
        var d = document.createElement('div');
        d.className = 'alert alert-danger py-2 mb-3';
        d.setAttribute('role', 'alert');
        d.textContent = msg;
        fb.appendChild(d);
    }
    function rcReset() { if (window.grecaptcha) { try { grecaptcha.reset(); } catch (e) {} } }

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        fb.innerHTML = '';
        var pw = document.getElementById('reset-password').value;
        var cf = document.getElementById('reset-confirm').value;
        if (pw !== cf) { fail('The passwords do not match.'); return; }

        TigerButton.run(btn, function () {
            return fetch('/auth/reset', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new URLSearchParams(new FormData(form))
            })
            .then(function (r) { return r.json().catch(function () { return {}; }); });
        })
        .then(function (res) {
            if (res && res.result === 1) { window.location = res.redirect || '/auth/login/reset/1'; return; }
            if (res && res.recaptcha) { rcReset(); fail('Please complete the reCAPTCHA and try again.'); return; }
            fail((res && res.message) ? res.message : 'Could not reset your password — the link may have expired.');
        })
        .catch(function () {
            rcReset();
            fail('Network error — please try again.');
        });
    });
});
</script>
