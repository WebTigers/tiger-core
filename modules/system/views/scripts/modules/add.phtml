<link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/tiger-lightbox/tiger-lightbox.css') ?>">
<script src="<?= $this->asset($this->themeAssets . '/vendor/tiger-lightbox/tiger-lightbox.js') ?>"></script>
<script src="<?= $this->asset($this->themeAssets . '/vendor/muuri/muuri.min.js') ?>"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var fb = document.getElementById('mod-feedback');
    var urlEl = document.getElementById('mod-url'), refEl = document.getElementById('mod-ref');
    var modalEl = document.getElementById('mod-detail');
    var modal = new bootstrap.Modal(modalEl);
    var head = document.getElementById('mod-detail-head'), body = document.getElementById('mod-detail-body'), foot = document.getElementById('mod-detail-foot');

    function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];}); }
    function badge(t,cls){ return '<span class="badge text-bg-'+cls+' me-1">'+esc(t)+'</span>'; }
    function api(method,data){ var b=new URLSearchParams(Object.assign({module:'system',service:'modules',method:method},data)); return fetch('/api',{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'},body:b}).then(function(r){return r.json();}); }
    var imgErr = "this.style.display='none'";

    // Open the detail modal for a repo (extra = registry listing fields: logo/hero/vendor/pricing…).
    // btn (optional) = the clicked trigger button, given a busy state while inspect runs.
    function openDetail(repo, ref, extra, btn){
        extra = extra || {};
        head.innerHTML = '<h5 class="modal-title mb-0">Loading…</h5>';
        body.innerHTML = '<div class="text-center py-5"><span class="spinner-border"></span></div>';
        foot.innerHTML = '';
        modal.show();
        var task = function(){ return api('inspect', { url: repo, ref: ref || '' }); };
        (btn ? TigerButton.run(btn, task) : task()).then(function(res){
            if (res.result !== 1){ body.innerHTML = ''; (res.messages||[]).forEach(function(m){ TigerDOM.notify(body, m.message, { type: m.class, replace: false }); }); return; }
            renderDetail(Object.assign({}, res.data, { _extra: extra }));
        }).catch(function(){ TigerDOM.notify(body, 'Network error.', { type: 'error' }); });
    }

    function renderDetail(d){
        var m = d.manifest, x = d._extra || {}, req = m.requires || {};
        var logo = x.logo || '';
        var vendor = x.vendor || m.author || '';
        head.innerHTML =
            (logo ? '<img src="'+esc(logo)+'" class="mod-logo" onerror="'+imgErr+'">' : '') +
            '<div><h5 class="modal-title mb-0">'+esc(m.name)+' '+(m.version?'<span class="text-body-secondary fs-6">v'+esc(m.version)+'</span>':'')+'</h5>'+
            '<div class="small text-body-secondary">'+(vendor?esc(vendor)+' · ':'')+'<code>/'+esc(m.slug)+'</code></div></div>';

        var reqBits=[]; if(req.tiger)reqBits.push('Tiger '+esc(req.tiger)); if(req.php)reqBits.push('PHP '+esc(req.php));
        var pricing = (x.pricing && x.pricing.model) || m.pricing;
        var media = [];
        if (x.video && x.video.src){ media.push({ type: x.video.type || 'video', src: x.video.src, poster: x.video.poster || '' }); }
        (Array.isArray(x.screenshots) ? x.screenshots : []).forEach(function(s){ media.push({ type:'image', src:s }); });
        var gallery = media.length ? '<div class="mod-shots d-flex flex-wrap gap-2">' +
            media.map(function(it,i){
                if (it.type === 'video' || it.type === 'iframe'){
                    return '<span class="mod-shot-vid" data-media="'+i+'" title="Play video">' +
                        (it.poster ? '<img src="'+esc(it.poster)+'" alt="" onerror="'+imgErr+'">' : '') +
                        '<i class="fa-solid fa-circle-play"></i></span>';
                }
                return '<img src="'+esc(it.src)+'" class="mod-shot" data-media="'+i+'" loading="lazy" alt="screenshot '+(i+1)+'" onerror="'+imgErr+'">';
            }).join('') +
            '</div>' : '';
        body.innerHTML =
            (x.hero ? '<img src="'+esc(x.hero)+'" class="mod-hero" onerror="'+imgErr+'">' : '') +
            gallery +
            '<div class="mb-2">' +
              ((pricing==='free'||pricing==='freemium') ? badge('free','success-subtle text-success-emphasis border border-success-subtle') : '') +
              ((pricing==='freemium'||pricing==='paid') ? badge('pro','primary-subtle text-primary-emphasis border border-primary-subtle') : '') +
              '<a href="'+esc(d.repo)+'" target="_blank" rel="noopener" class="badge text-bg-light text-decoration-none"><i class="fa-brands fa-github me-1"></i>'+esc(d.repo.replace('https://github.com/',''))+'@'+esc(d.ref)+'</a>' +
              (reqBits.length?' <span class="small text-body-secondary ms-1">Requires '+reqBits.join(', ')+'</span>':'') +
            '</div>' +
            (m.description ? '<p>'+esc(m.description)+'</p>' : '') +
            (d.description_html ? '<hr><div class="mod-readme">'+d.description_html+'</div>' : '<p class="text-body-secondary small">No TIGER.md provided.</p>');

        body.querySelectorAll('[data-media]').forEach(function(el){
            el.addEventListener('click', function(){
                if (window.TigerLightbox){ TigerLightbox.open(media.map(function(it){ return { type: it.type, src: it.src }; }), +el.getAttribute('data-media')); }
            });
        });

        foot.innerHTML = d.installed
            ? '<span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>Installed'+(d.installed_version?' (v'+esc(d.installed_version)+')':'')+'</span>'
            : '<button type="button" class="btn btn-primary" id="mod-do"><i class="fa-solid fa-download me-1"></i>Install</button>';
        var doBtn = document.getElementById('mod-do');
        if (doBtn){ doBtn.addEventListener('click', function(){ doInstall(d.repo, d.ref, false); }); }
    }

    function doInstall(repo, ref, isUpdate){
        if (!confirm((isUpdate?'Update':'Install')+' this module? Its code will run in your app once active.')) return;
        var b=document.getElementById('mod-do');
        TigerButton.run(b, function(){
            return api('install',{url:repo,ref:ref,force:isUpdate?1:0});
        }).then(function(res){
            if (res.result===1){ window.location=res.redirect||'/system/modules'; return; }
            modal.hide(); fb.innerHTML=''; (res.messages||[]).forEach(function(m){ TigerDOM.notify(fb, m.message, { type: m.class, replace: false }); }); window.scrollTo({top:0,behavior:'smooth'});
        }).catch(function(){});
    }

    document.getElementById('mod-check').addEventListener('click', function(){ var u=urlEl.value.trim(); if(u){ openDetail(u, refEl.value.trim(), {}, this); } });
    urlEl.addEventListener('keydown', function(e){ if(e.key==='Enter'){ document.getElementById('mod-check').click(); } });

    // Upload install — drag-drop zone + click-to-browse; the file rides in FormData (multipart).
    var uploadBtn = document.getElementById('mod-upload'), fileEl = document.getElementById('mod-file');
    var dropzone = document.getElementById('mod-dropzone'), dropLabel = document.getElementById('mod-drop-label');
    var pickedFile = null;
    function pickFile(file){
        if (!file){ return; }
        if (!/\.zip$/i.test(file.name)){ TigerDOM.notify(fb, 'Please choose a .zip package.', { type:'alert' }); return; }
        pickedFile = file;
        dropLabel.innerHTML = '<i class="fa-solid fa-file-zipper text-success me-1"></i>'+esc(file.name)+' <span class="text-body-secondary">('+(file.size/1048576).toFixed(1)+' MB)</span>';
        dropzone.classList.add('has-file');
        uploadBtn.disabled = false;
    }
    if (dropzone){
        dropzone.addEventListener('click', function(){ fileEl.click(); });
        dropzone.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); fileEl.click(); } });
        fileEl.addEventListener('change', function(){ pickFile(fileEl.files[0]); });
        ['dragenter','dragover'].forEach(function(ev){ dropzone.addEventListener(ev, function(e){ e.preventDefault(); dropzone.classList.add('dragover'); }); });
        ['dragleave','dragend','drop'].forEach(function(ev){ dropzone.addEventListener(ev, function(e){ e.preventDefault(); dropzone.classList.remove('dragover'); }); });
        dropzone.addEventListener('drop', function(e){ pickFile(e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]); });
        // stop the browser from navigating to a file dropped outside the zone
        ['dragover','drop'].forEach(function(ev){ window.addEventListener(ev, function(e){ if(!dropzone.contains(e.target)){ e.preventDefault(); } }); });
    }
    if (uploadBtn){
        uploadBtn.addEventListener('click', function(){
            if (!pickedFile){ TigerDOM.notify(fb, 'Choose a .zip package to upload.', { type:'alert' }); return; }
            if (!confirm('Install this uploaded package? Its code will run in your app once active.')) { return; }
            var fd = new FormData();
            fd.append('module','system'); fd.append('service','modules'); fd.append('method','upload');
            fd.append('archive', pickedFile);
            TigerButton.run(this, function(){
                return fetch('/api',{ method:'POST', headers:{ 'X-Requested-With':'XMLHttpRequest' }, body: fd }).then(function(r){ return r.json().catch(function(){ return {}; }); });
            }).then(function(res){
                if (res && res.result===1){ window.location = res.redirect || '/system/modules'; return; }
                fb.innerHTML=''; ((res&&res.messages)||[]).forEach(function(m){ TigerDOM.notify(fb, m.message, { type: m.class, replace:false }); }); window.scrollTo({ top:0, behavior:'smooth' });
            }).catch(function(){ TigerDOM.notify(fb, 'Upload failed — please try again.', { type:'error' }); });
        });
    }

    // Registry search + type filter — a Muuri masonry grid (variable-height cards; theme cards
    // show their hero full-height). Search re-fetches + rebuilds; the type pills filter in place.
    var searchEl=document.getElementById('mod-search'), sortEl=document.getElementById('mod-sort'),
        results=document.getElementById('mod-results'), typeFilter=document.getElementById('mod-type-filter'), t;
    var allResults=[], activeType='', grid=null;
    if (searchEl){
        searchEl.addEventListener('input', function(){ clearTimeout(t); t=setTimeout(runSearch,250); });
        if (sortEl){ sortEl.addEventListener('change', runSearch); }
        runSearch();
    }
    if (typeFilter){
        typeFilter.querySelectorAll('[data-type]').forEach(function(btn){
            btn.addEventListener('click', function(){
                typeFilter.querySelectorAll('.nav-link').forEach(function(b){ b.classList.remove('active'); });
                btn.classList.add('active');
                activeType = btn.getAttribute('data-type');
                applyFilter();
            });
        });
    }
    function runSearch(){
        api('search',{q:searchEl.value.trim(), sort:(sortEl?sortEl.value:'featured')}).then(function(res){
            if (res.result!==1) return;
            allResults=(res.data&&res.data.results)||[];
            renderResults();
        });
    }
    function card(m,i){
        var type = m.type || 'plugin';
        var typeBadge = ' <span class="badge text-bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">'+({theme:'Theme',app:'App',plugin:'Plugin',code:'Code'}[type]||'Plugin')+'</span>';
        var pm = (m.pricing && m.pricing.model) || '';
        var pricingBadges =
            ((pm==='free'||pm==='freemium') ? ' <span class="badge text-bg-success-subtle text-success-emphasis border border-success-subtle">free</span>' : '') +
            ((pm==='freemium'||pm==='paid') ? ' <span class="badge text-bg-primary-subtle text-primary-emphasis border border-primary-subtle" title="Paid pro version available">pro</span>' : '');
        var spon = m.sponsored?' <span class="badge text-bg-warning-subtle text-warning-emphasis border border-warning-subtle" title="Promoted placement">'+esc(m.sponsored_label||'Sponsored')+'</span>':'';
        var hero = m.hero ? '<img src="'+esc(m.hero)+'" class="mod-card-hero" alt="" onerror="'+imgErr+'">' : '';
        return '<div class="mod-grid-item" data-type="'+esc(type)+'"><div class="mod-grid-item-content card'+(m.sponsored?' border-warning-subtle':'')+'">'+
            hero +
            '<div class="card-body d-flex gap-3">'+
              (m.logo?'<img src="'+esc(m.logo)+'" class="mod-card-logo" onerror="'+imgErr+'">':'')+
              '<div class="flex-grow-1">'+
                '<h6 class="mb-0">'+esc(m.module||m.slug)+typeBadge+pricingBadges+spon+'</h6>'+
                '<div class="small text-body-secondary mb-1">'+esc(m.vendor||'')+'</div>'+
                '<p class="small text-body-secondary mb-2">'+esc(m.description||'')+'</p>'+
                '<button type="button" class="btn btn-sm btn-outline-primary" data-i="'+i+'">View more</button>'+
              '</div>'+
            '</div>'+
          '</div></div>';
    }
    function renderResults(){
        if (grid){ grid.destroy(); grid=null; }
        if (!allResults.length){ results.innerHTML='<div class="text-body-secondary small">No modules match.</div>'; return; }
        results.innerHTML = '<div class="mod-grid">'+allResults.map(card).join('')+'</div>'+
            '<div class="mod-empty text-body-secondary small d-none">No modules of this type yet.</div>';
        grid = new Muuri(results.querySelector('.mod-grid'), { dragEnabled:false, layout:{ fillGaps:true } });
        applyFilter();
        // heroes/logos load async — re-pack as each finishes so heights are right
        results.querySelectorAll('img').forEach(function(img){
            img.addEventListener('load', function(){ if(grid){ grid.refreshItems().layout(); } });
        });
        results.querySelectorAll('[data-i]').forEach(function(b){
            b.addEventListener('click', function(){ var m=allResults[+b.getAttribute('data-i')]; openDetail(m.repository, m.ref, m, this); });
        });
    }
    function applyFilter(){
        if (!grid){ return; }
        grid.filter(function(item){ return !activeType || item.getElement().getAttribute('data-type')===activeType; });
        var visible = allResults.filter(function(m){ return !activeType || (m.type||'plugin')===activeType; }).length;
        var empty = results.querySelector('.mod-empty');
        if (empty){ empty.classList.toggle('d-none', visible>0); }
    }
});
</script>
