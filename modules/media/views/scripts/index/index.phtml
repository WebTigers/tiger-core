/**
 * Media Library (admin shell). A drag-drop uploader over two views of the same /api data
 * (Media_Service_Media::datatable): a DataTables **List** and a vanilla CSS-grid
 * **Portfolio** (no Isotope — MIT-clean, zero-dep). Shared search + type filter; the grid
 * adds a size selector (thumbnail/small/medium/large) and opens images in TigerLightbox.
 * The reusable picker + pdf.js previews are the remaining P3 pieces (see MEDIA.md).
 */
?>
<link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/tiger-lightbox/tiger-lightbox.css') ?>">
<script src="<?= $this->asset($this->themeAssets . '/vendor/tiger-lightbox/tiger-lightbox.js') ?>" defer></script>
<script src="<?= $this->asset($this->themeAssets . '/vendor/tiger-upload/tiger-upload.js') ?>"></script>

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">Media Library</h1>
        <p class="text-body-secondary mb-0">Images, documents, PDFs, video, and archives — drag &amp; drop to upload.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <select id="media-vis" class="form-select form-select-sm" style="width:auto;" title="Visibility for new uploads">
            <option value="public">Public</option>
            <option value="private">Private</option>
        </select>
        <button type="button" id="media-browse" class="btn btn-primary"><i class="fa-solid fa-arrow-up-from-bracket me-2"></i>Upload</button>
        <input type="file" id="media-input" multiple hidden>
    </div>
</div>

<div class="card">
    <div class="card-header bg-transparent">
        <div class="row g-2 align-items-center">
            <div class="col-12 col-md">
                <input type="search" id="media-search" class="form-control form-control-sm" placeholder="Search filename, title, caption…">
            </div>
            <div class="col-auto">
                <select id="media-kind" class="form-select form-select-sm">
                    <option value="">All types</option>
                    <option value="image">Images</option>
                    <option value="pdf">PDFs</option>
                    <option value="document">Documents</option>
                    <option value="video">Video</option>
                    <option value="audio">Audio</option>
                    <option value="archive">Archives</option>
                </select>
            </div>
            <div class="col-auto" id="media-size-wrap" hidden>
                <select id="media-size" class="form-select form-select-sm" title="Tile size">
                    <option value="thumbnail">Thumbnail</option>
                    <option value="small" selected>Small</option>
                    <option value="medium">Medium</option>
                    <option value="large">Large</option>
                </select>
            </div>
            <div class="col-auto">
                <div class="btn-group btn-group-sm" role="group" aria-label="View">
                    <button type="button" class="btn btn-outline-secondary active" id="media-view-list" title="List"><i class="fa-solid fa-list"></i></button>
                    <button type="button" class="btn btn-outline-secondary" id="media-view-grid" title="Portfolio"><i class="fa-solid fa-table-cells"></i></button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div id="media-list" class="table-responsive">
            <table id="media-table" class="table table-hover align-middle" style="width:100%;">
                <thead><tr>
                    <th style="width:64px;" data-orderable="false"></th>
                    <th>File</th><th>Type</th><th>Size</th><th>Visibility</th>
                    <th class="text-end" data-orderable="false">Actions</th>
                </tr></thead>
            </table>
        </div>
        <div id="media-grid-wrap" hidden>
            <div id="media-grid"></div>
            <div class="text-center mt-3">
                <button type="button" id="media-more" class="btn btn-outline-secondary btn-sm" hidden>Load more</button>
                <div id="media-grid-empty" class="text-body-secondary py-4" hidden>Nothing here yet.</div>
            </div>
        </div>
    </div>
</div>

<script>
var MEDIA_CLIENT_THUMB = <?= !empty($this->clientThumb) ? 'true' : 'false' ?>;
var MEDIA_THUMB_PX     = <?= (int) ($this->thumbPx ?? 200) ?>;
var PDFJS_URL          = '<?= $this->asset($this->themeAssets . '/vendor/pdfjs/pdf.js') ?>';
var PDFJS_WORKER       = '<?= $this->asset($this->themeAssets . '/vendor/pdfjs/pdf.worker.js') ?>';
document.addEventListener('DOMContentLoaded', function () {
    var $ = jQuery, esc = tigerDataTable.esc;
    var KIND_ICON = { image:'fa-image', pdf:'fa-file-pdf', document:'fa-file-lines', video:'fa-film', audio:'fa-music', archive:'fa-file-zipper', other:'fa-file' };
    var TILE_PX   = { thumbnail:120, small:168, medium:240, large:336 };
    function human(n){ n=+n||0; var u=['B','KB','MB','GB']; var i=0; while(n>=1024&&i<u.length-1){n/=1024;i++;} return (i?n.toFixed(1):n)+' '+u[i]; }
    function icon(k){ return '<i class="fa-solid '+(KIND_ICON[k]||'fa-file')+'"></i>'; }

    var mode = 'list';
    var searchEl = document.getElementById('media-search'), kindEl = document.getElementById('media-kind'),
        sizeEl = document.getElementById('media-size'), grid = document.getElementById('media-grid');

    // ---------- List (DataTables) ----------
    function imgAnchor(row, imgSrc, cls){
        return '<a href="'+esc(row.large||row.url)+'" data-tiger-lightbox="media" data-type="image" data-caption="'+esc(row.title||row.filename||'')+'">'
             + '<img src="'+esc(imgSrc)+'" alt="'+esc(row.alt_text||row.filename||'')+'" '+cls+'></a>';
    }
    var table = tigerDataTable('#media-table', {
        service: { module:'media', service:'media', action:'datatable' },
        order: [[1,'desc']],
        extraData: function(){ return { kind: kindEl.value }; },
        columns: [
            { data:null, orderable:false, className:'text-center', render:function(t,type,row){
                if (row.kind==='image' && row.thumb) { return imgAnchor(row, row.thumb, 'class="rounded" style="width:48px;height:48px;object-fit:cover;cursor:zoom-in;"'); }
                return '<span class="d-inline-flex align-items-center justify-content-center rounded bg-body-secondary text-body-secondary" style="width:48px;height:48px;">'+icon(row.kind)+'</span>'; } },
            { data:'filename', render:function(t,type,row){ if(type!=='display')return t;
                return '<div class="fw-semibold text-truncate" style="max-width:340px;">'+esc(row.filename||row.title||'(file)')+'</div>'
                     + (row.title && row.title!==row.filename ? '<div class="small text-body-secondary text-truncate" style="max-width:340px;">'+esc(row.title)+'</div>' : ''); } },
            { data:'kind', render:function(t,type){ return type!=='display'?t:'<span class="badge text-bg-light">'+icon(t)+' '+esc(t)+'</span>'; } },
            { data:'file_size', render:function(t,type){ return type!=='display'?t:human(t); } },
            { data:'visibility', render:function(t,type){ return type!=='display'?t:'<span class="badge text-bg-'+(t==='public'?'success':'secondary')+'">'+esc(t)+'</span>'; } },
            { data:null, orderable:false, searchable:false, className:'text-end text-nowrap', render:function(t,type,row){
                var h = '<a href="'+esc(row.url)+'" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary" title="Open"><i class="fa-solid fa-up-right-from-square"></i></a> ';
                h += row.can_delete ? '<button type="button" class="btn btn-sm btn-outline-danger" data-media-delete="'+esc(row.media_id)+'" title="Delete"><i class="fa-solid fa-trash"></i></button>'
                                    : '<button type="button" class="btn btn-sm btn-outline-danger" disabled><i class="fa-solid fa-trash"></i></button>';
                return h; } }
        ]
    });

    // ---------- Grid (vanilla) ----------
    var gRows = [], gOffset = 0, gTotal = 0, GLEN = 60, gBusy = false;
    function variantSrc(row){ var m={thumbnail:'thumb',small:'small',medium:'medium',large:'large'}; return row[m[sizeEl.value]] || row.thumb || row.url; }
    function tile(row){
        var del = row.can_delete ? '<button class="media-tile-del" data-media-delete="'+esc(row.media_id)+'" title="Delete">&times;</button>' : '';
        var name = '<div class="media-tile-name" title="'+esc(row.filename||'')+'">'+esc(row.title||row.filename||'')+'</div>';
        if (row.kind==='image'){
            return '<div class="media-tile" data-media-id="'+esc(row.media_id)+'">'
                 + '<a href="'+esc(row.large||row.url)+'" data-tiger-lightbox="media" data-type="image" data-caption="'+esc(row.title||row.filename||'')+'">'
                 + '<img src="'+esc(variantSrc(row))+'" loading="lazy" alt="'+esc(row.alt_text||row.filename||'')+'"></a>'+del+name+'</div>';
        }
        if (row.kind==='pdf'){
            // Icon now; pdf.js paints the first page into this anchor after render (opens in the lightbox).
            return '<div class="media-tile" data-media-id="'+esc(row.media_id)+'">'
                 + '<a href="'+esc(row.url)+'" data-tiger-lightbox="media" data-type="pdf" data-caption="'+esc(row.title||row.filename||'')+'" class="media-tile-icon" data-pdf-src="'+esc(row.url)+'">'+icon('pdf')+'<span class="small text-uppercase">pdf</span></a>'+del+name+'</div>';
        }
        return '<div class="media-tile" data-media-id="'+esc(row.media_id)+'">'
             + '<a href="'+esc(row.url)+'" target="_blank" rel="noopener" class="media-tile-icon">'+icon(row.kind)+'<span class="small text-uppercase">'+esc(row.extension||row.kind)+'</span></a>'+del+name+'</div>';
    }
    function renderGrid(){
        grid.style.setProperty('--tile', (TILE_PX[sizeEl.value]||168)+'px');
        grid.innerHTML = gRows.map(tile).join('');
        document.getElementById('media-grid-empty').hidden = gRows.length > 0;
        document.getElementById('media-more').hidden = gRows.length >= gTotal;
        renderPdfPreviews();
    }

    // Lazy pdf.js: load once (only when a PDF needs a preview), render each PDF's first
    // page into its tile (the icon stays until the canvas paints).
    var _pdfjs = null;
    function loadPdfjs(){
        if (!_pdfjs) {
            _pdfjs = import(PDFJS_URL).then(function(lib){ lib.GlobalWorkerOptions.workerSrc = PDFJS_WORKER; return lib; });
        }
        return _pdfjs;
    }
    function renderPdfPreviews(){
        grid.querySelectorAll('[data-pdf-src]:not([data-pdf-done])').forEach(function(el){
            el.setAttribute('data-pdf-done', '1');
            var url = el.getAttribute('data-pdf-src');
            loadPdfjs()
                .then(function(lib){ return lib.getDocument(url).promise; })
                .then(function(pdf){ return pdf.getPage(1); })
                .then(function(page){
                    var box = el.clientWidth || (TILE_PX[sizeEl.value] || 168);
                    var vp  = page.getViewport({ scale: box / page.getViewport({ scale: 1 }).width });
                    var canvas = document.createElement('canvas');
                    canvas.width = Math.ceil(vp.width); canvas.height = Math.ceil(vp.height);
                    canvas.style.width = '100%'; canvas.style.height = '100%'; canvas.style.objectFit = 'cover'; canvas.style.background = '#fff';
                    return page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise
                        .then(function(){ el.innerHTML = ''; el.appendChild(canvas); });
                })
                .catch(function(){ /* keep the icon on any failure */ });
        });
    }
    function gridFetch(reset){
        if (gBusy) { return; }
        gBusy = true;
        if (reset) { gOffset = 0; gRows = []; }
        var body = new URLSearchParams({ module:'media', service:'media', method:'datatable', draw:1, start:gOffset, length:GLEN });
        body.set('search[value]', searchEl.value); body.set('kind', kindEl.value);
        fetch('/api', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}, body:body })
            .then(function(r){ return r.json(); })
            .then(function(res){
                gBusy = false;
                if (!res || res.result!==1 || !res.data) { return; }
                gTotal = res.data.recordsFiltered || 0;
                gRows = gRows.concat(res.data.data || []);
                gOffset = gRows.length;
                renderGrid();
            }).catch(function(){ gBusy = false; });
    }
    document.getElementById('media-more').addEventListener('click', function(){ gridFetch(false); });
    sizeEl.addEventListener('change', renderGrid);   // variant + tile-size swap, no refetch

    // ---------- shared toolbar + view toggle ----------
    function refresh(){ if (mode==='grid') { gridFetch(true); } else { table.ajax.reload(null,false); } }
    var t;
    searchEl.addEventListener('input', function(){ clearTimeout(t); t=setTimeout(function(){ if(mode==='grid') gridFetch(true); else table.search(searchEl.value).draw(); }, 250); });
    kindEl.addEventListener('change', function(){ if(mode==='grid') gridFetch(true); else table.ajax.reload(); });

    function setMode(m){
        mode = m;
        document.getElementById('media-list').hidden = (m==='grid');
        document.getElementById('media-grid-wrap').hidden = (m!=='grid');
        document.getElementById('media-size-wrap').hidden = (m!=='grid');
        document.getElementById('media-view-list').classList.toggle('active', m==='list');
        document.getElementById('media-view-grid').classList.toggle('active', m==='grid');
        if (m==='grid') { gridFetch(true); }
    }
    document.getElementById('media-view-list').addEventListener('click', function(){ setMode('list'); });
    document.getElementById('media-view-grid').addEventListener('click', function(){ setMode('grid'); });

    // ---------- delete (delegated — works in both views) ----------
    document.addEventListener('click', function(e){
        var b = e.target.closest('[data-media-delete]');
        if (!b) { return; }
        if (!confirm('Delete this file? The stored bytes are removed.')) { return; }
        TigerButton.run(b, function(){
            return fetch('/api', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}, body:new URLSearchParams({ module:'media', service:'media', method:'delete', media_id:b.getAttribute('data-media-delete') }) });
        }).then(function(){ refresh(); }).catch(function(){ refresh(); });
    });

    // ---------- upload (TigerUpload engine → BOTH views as independent subscribers) ----------
    // One upload event, broadcast to: (1) the List renderer — temp <tr>s with a thumb + bar;
    // (2) the Portfolio renderer — larger tiles with a bar; (3) a coordinator that toasts errors
    // and reconciles each view with the server-canonical rows on batch end. Same engine, three views.
    var input = document.getElementById('media-input'),
        visEl = document.getElementById('media-vis'), listBody = document.querySelector('#media-table tbody');
    function kindOfMime(t){ t=t||'';
        if (/^image\//.test(t)) { return 'image'; } if (t==='application/pdf') { return 'pdf'; }
        if (/^video\//.test(t)) { return 'video'; } if (/^audio\//.test(t)) { return 'audio'; }
        if (/(zip|compressed|tar|rar|7z)/.test(t)) { return 'archive'; }
        if (/^text\/|word|excel|powerpoint|officedocument|opendocument/.test(t)) { return 'document'; }
        return 'other'; }

    // Client-side thumbnail (downscaled JPEG) — kept from the previous uploader, now fed through the
    // engine's prepare() hook so the engine owns transport while the app owns the extra field.
    function makeThumb(file, maxEdge){
        return new Promise(function(resolve){
            if (!/^image\//.test(file.type) || /svg/.test(file.type)) { resolve(null); return; }
            var img = new Image(), url = URL.createObjectURL(file);
            img.onload = function(){
                var s = Math.min(1, maxEdge/Math.max(img.width,img.height));
                var w = Math.max(1,Math.round(img.width*s)), h = Math.max(1,Math.round(img.height*s));
                var c = document.createElement('canvas'); c.width=w; c.height=h; c.getContext('2d').drawImage(img,0,0,w,h);
                URL.revokeObjectURL(url); c.toBlob(function(b){ resolve(b); }, 'image/jpeg', 0.9);
            };
            img.onerror = function(){ URL.revokeObjectURL(url); resolve(null); };
            img.src = url;
        });
    }

    if (window.TigerUpload) {
        var up = TigerUpload.create({
            url: '/api', field: 'file', auto: true, concurrency: 3,
            params: { module: 'media', service: 'media', method: 'upload' },
            prepare: function (item, fd) {
                fd.set('visibility', visEl.value);                       // dynamic — read at send time
                if (MEDIA_CLIENT_THUMB && item.isImage) {
                    return makeThumb(item.file, MEDIA_THUMB_PX).then(function (blob) { if (blob) { fd.append('thumbnail', blob, 'thumb.jpg'); } });
                }
            }
        });
        up.fromInput(input);
        up.dropOnWindow({ label: 'Drop to upload', sublabel: 'images · video · PDFs · documents · archives' });
        document.getElementById('media-browse').addEventListener('click', function () { input.click(); });

        // Subscriber #1 — LIST view: a temp table row with a thumbnail cell + a progress bar.
        var listRows = {};
        up.subscribe({
            onAdd: function (item) {
                var tr = document.createElement('tr'); tr.className = 'media-uploading';
                var thumb = item.previewUrl
                    ? '<img src="' + item.previewUrl + '" class="rounded" style="width:48px;height:48px;object-fit:cover;">'
                    : '<span class="d-inline-flex align-items-center justify-content-center rounded bg-body-secondary text-body-secondary" style="width:48px;height:48px;">' + icon(kindOfMime(item.type)) + '</span>';
                tr.innerHTML =
                    '<td class="text-center">' + thumb + '</td>' +
                    '<td><div class="fw-semibold text-truncate" style="max-width:340px;">' + esc(item.name) + '</div>' +
                        '<div class="progress mt-1" style="height:5px;"><div class="progress-bar progress-bar-striped progress-bar-animated" style="width:0%"></div></div></td>' +
                    '<td><span class="badge text-bg-info-subtle text-info-emphasis">Uploading…</span></td>' +
                    '<td class="text-body-secondary">' + human(item.size) + '</td><td></td>' +
                    '<td class="text-end"><span class="spinner-border spinner-border-sm text-secondary" role="status" aria-hidden="true"></span></td>';
                if (listBody) { listBody.insertBefore(tr, listBody.firstChild); }
                listRows[item.id] = tr;
            },
            onProgress: function (item) { var tr = listRows[item.id]; if (tr) { tr.querySelector('.progress-bar').style.width = item.percent + '%'; } },
            onSuccess: function (item) { var tr = listRows[item.id]; if (!tr) { return; }
                var b = tr.querySelector('.progress-bar'); b.style.width = '100%'; b.classList.remove('progress-bar-animated'); b.classList.add('bg-success');
                var badge = tr.querySelector('.badge'); badge.className = 'badge text-bg-success'; badge.textContent = 'Done';
                tr.querySelector('td:last-child').innerHTML = '<i class="fa-solid fa-circle-check text-success"></i>'; },
            onError: function (item) { var tr = listRows[item.id]; if (!tr) { return; }
                tr.classList.add('table-danger');
                var b = tr.querySelector('.progress-bar'); if (b) { b.classList.remove('progress-bar-animated'); b.classList.add('bg-danger'); }
                tr.querySelector('td:nth-child(3)').innerHTML = '<span class="small text-danger">' + esc(item.error || 'Failed') + '</span>';
                tr.querySelector('td:last-child').innerHTML = ''; }
        });

        // Subscriber #2 — PORTFOLIO view: a larger tile with a thumbnail + a progress bar overlay.
        var gridTiles = {};
        up.subscribe({
            onAdd: function (item) {
                var d = document.createElement('div'); d.className = 'media-tile media-uploading'; d.style.position = 'relative';
                var pic = item.previewUrl
                    ? '<img src="' + item.previewUrl + '" alt="" style="width:100%;height:100%;object-fit:cover;">'
                    : '<div class="media-tile-icon">' + icon(kindOfMime(item.type)) + '<span class="small text-uppercase">' + esc((item.name.split('.').pop() || '').slice(0, 4)) + '</span></div>';
                d.innerHTML = pic +
                    '<div class="progress" style="position:absolute;left:6px;right:6px;bottom:26px;height:5px;"><div class="progress-bar progress-bar-striped progress-bar-animated" style="width:0%"></div></div>' +
                    '<div class="media-tile-name">' + esc(item.name) + '</div>';
                grid.insertBefore(d, grid.firstChild);
                document.getElementById('media-grid-empty').hidden = true;
                gridTiles[item.id] = d;
            },
            onProgress: function (item) { var d = gridTiles[item.id]; if (d) { d.querySelector('.progress-bar').style.width = item.percent + '%'; } },
            onSuccess: function (item) { var d = gridTiles[item.id]; if (!d) { return; }
                var b = d.querySelector('.progress-bar'); b.style.width = '100%'; b.classList.remove('progress-bar-animated'); b.classList.add('bg-success'); },
            onError: function (item) { var d = gridTiles[item.id]; if (!d) { return; }
                d.classList.add('border', 'border-danger');
                var b = d.querySelector('.progress-bar'); if (b) { b.classList.remove('progress-bar-animated'); b.classList.add('bg-danger'); } }
        });

        // Subscriber #3 — coordinator: user-facing messages + reconcile each view with the server on
        // batch end (temp rows/tiles are optimistic; the reload swaps in the real, id'd rows).
        var upErrors = [];
        up.subscribe({
            onReject: function (info) { TigerDOM.toast('“' + info.name + '” — ' + info.error, { type: 'alert' }); },
            onError:  function (item) { upErrors.push(item.name + ' — ' + (item.error || 'failed')); },
            onComplete: function () {
                table.ajax.reload(null, false);                          // list: temp rows → real rows
                if (mode === 'grid') { gridFetch(true); }                // grid (if open): temp tiles → real tiles
                if (upErrors.length) { TigerDOM.toast(upErrors.length + ' file' + (upErrors.length > 1 ? 's' : '') + ' failed: ' + upErrors.join('; '), { type: 'error' }); upErrors = []; }
            }
        });
    }
});
</script>
