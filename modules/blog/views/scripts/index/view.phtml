/**
 * Single article ‚Äî the public Medium-style reading layout (kicker ¬∑ title ¬∑ subtitle ¬∑
 * meta ¬∑ preamble ¬∑ body ¬∑ footer). Renders in the theme's PUBLIC layout. Data is
 * Blog_Model_Post::present() + rendered body + terms; a theme can override this view.
 * The body is trusted server-rendered HTML (Tiger_Cms_Renderer) ‚Äî output raw.
 */
$a    = $this->article;
$date = $a['published_at'] ? date('F j, Y', strtotime((string) $a['published_at'])) : '';
?>

<article class="post-wrap">
  <?php if ($a['feature']): ?>
    <img class="post-hero" src="<?= $this->escape($a['feature']['url']) ?>" alt="">
  <?php endif; ?>

  <?php if ($a['kicker']): ?><div class="post-kicker"><?= $this->escape($a['kicker']) ?></div><?php endif; ?>
  <h1 class="post-title"><?= $this->escape($a['title']) ?></h1>
  <?php if ($a['subtitle']): ?><p class="post-subtitle"><?= $this->escape($a['subtitle']) ?></p><?php endif; ?>

  <div class="post-meta">
    <?php if (!empty($a['author']['name'])): ?><span class="who"><?= $this->escape($a['author']['name']) ?></span><?php endif; ?>
    <?php if ($date): ?><span>¬∑</span><span><?= $this->escape($date) ?></span><?php endif; ?>
    <?php if ($a['reading_time']): ?><span>¬∑</span><span><?= (int) $a['reading_time'] ?> min read</span><?php endif; ?>
  </div>

  <?php if ($a['preamble']): ?><div class="post-preamble"><?= $this->escape($a['preamble']) ?></div><?php endif; ?>

  <div class="post-body"><?= $a['body'] ?></div>

  <?php if (!empty($a['categories']) || !empty($a['tags'])): ?>
    <footer class="post-footer post-terms">
      <?php foreach ($a['categories'] as $c): ?>
        <a href="/blog/category/<?= $this->escape($c['slug']) ?>" class="badge rounded-pill text-bg-primary me-1 mb-1"><?= $this->escape($c['name']) ?></a>
      <?php endforeach; ?>
      <?php foreach ($a['tags'] as $t): ?>
        <a href="/blog/tag/<?= $this->escape($t['slug']) ?>" class="badge rounded-pill text-bg-light border me-1 mb-1">#<?= $this->escape($t['name']) ?></a>
      <?php endforeach; ?>
    </footer>
  <?php endif; ?>
</article>
