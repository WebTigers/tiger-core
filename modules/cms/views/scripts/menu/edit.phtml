<?php
/**
 * CMS Menu builder — a two-pane, drag-drop menu editor (WordPress Appearance→Menus feel).
 *
 *  LEFT  = tabbed, filterable SOURCES (Pages, Custom). Each source is a chip that LOOKS
 *          like a menu item and DRAGS into the structure (no checkbox + "Add" button).
 *  RIGHT = the menu STRUCTURE — a FLAT SortableJS list where each item carries a `depth`.
 *          Drag vertically to reorder; drag HORIZONTALLY to indent/outdent (WP-style) — an
 *          item can go at most one level deeper than the row above it. Parent/child is
 *          derived from order + depth at save time (computeTree), so the DOM's flat order +
 *          each row's `data-depth` is the single source of truth.
 *
 * Dropping a source inserts the item (/api save); any drag persists order+nesting
 * (/api reorder); each chip's ⚙ opens a scrollable PROPERTIES modal (/api save on submit,
 * closing it with a "‹label› saved" toast). Delete removes the item + its subtree. The
 * server renders the initial flat tree; SortableJS enhances it. This markup is admin-only —
 * the PUBLIC render is Tiger_Menu::getHTML.
 */
$menuKey = (string) $this->menuKey;
$isNew   = ($menuKey === '');
$f       = $this->form;

/** One item's chip markup (kept in sync with chipHTML() in JS below). */
$chip = function ($n) {
    $label = ($n['label'] !== null && $n['label'] !== '') ? $n['label'] : '(no label)';
    $hint  = !empty($n['page_key']) ? ('#' . $n['page_key'])
           : (!empty($n['url']) && $n['url'] !== '#' ? $n['url'] : (($n['url'] ?? '') === '#' ? '(set link)' : 'heading'));
    $h  = '<div class="menu-chip">';
    $h .= '<span class="menu-grip" title="Drag to move · drag right/left to nest"><i class="fa-solid fa-grip-vertical"></i></span>';
    if (!empty($n['icon'])) { $h .= '<i class="' . $this->escape($n['icon']) . '"></i>'; }
    $h .= '<span class="menu-chip-label">' . $this->escape($label) . '</span>';
    $h .= ' <code class="menu-chip-hint">' . $this->escape($hint) . '</code>';
    if (($n['status'] ?? '') === 'draft') { $h .= ' <span class="badge text-bg-secondary">Draft</span>'; }
    $h .= '<span class="menu-chip-actions ms-auto">'
       .  '<button type="button" class="btn btn-sm btn-outline-secondary" data-open title="Properties"><i class="fa-solid fa-sliders"></i></button> '
       .  '<button type="button" class="btn btn-sm btn-outline-danger" data-del title="Remove"><i class="fa-solid fa-trash"></i></button>'
       .  '</span></div>';
    return $h;
};
/** Flatten the tree into one flat list of <li data-depth> (depth-first, WP-style). */
$flatten = function ($nodes, $depth) use (&$flatten, $chip) {
    $html = '';
    foreach ($nodes as $n) {
        $html .= '<li class="menu-item" data-menu-id="' . $this->escape($n['menu_id']) . '" data-depth="' . (int) $depth . '" style="--depth:' . (int) $depth . ';">'
              .  $chip($n) . '</li>';
        $html .= $flatten($n['children'] ?? [], $depth + 1);
    }
    return $html;
};

// Flat map for the properties modal to prefill from.
$flat = [];
$collect = function ($nodes) use (&$collect, &$flat) {
    foreach ($nodes as $n) {
        $flat[$n['menu_id']] = [
            'label' => $n['label'], 'page_key' => $n['page_key'], 'url' => $n['url'],
            'icon' => $n['icon'], 'css_class' => $n['css_class'], 'dom_id' => $n['dom_id'],
            'link_target' => $n['link_target'], 'link_rel' => $n['link_rel'],
            'resource' => $n['resource'], 'privilege' => $n['privilege'], 'status' => $n['status'],
        ];
        $collect($n['children'] ?? []);
    }
};
$collect($this->tree);
?>
