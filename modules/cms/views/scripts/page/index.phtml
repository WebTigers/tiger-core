}, $this->themeTemplates), JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
</script>
<?php endif; ?>

<script>
document.addEventListener('DOMContentLoaded', function () {
    if (typeof tigerDataTable !== 'function') { return; }
    var $   = jQuery;
    var esc = tigerDataTable.esc;
    var TYPE_ICON = { page: 'fa-file-lines', layout: 'fa-table-columns', partial: 'fa-puzzle-piece' };
    var BADGE     = { published: 'success', draft: 'secondary', archived: 'warning' };
    function cap(s) { s = String(s || ''); return s.charAt(0).toUpperCase() + s.slice(1); }

    var fStatus = document.getElementById('cms-filter-status');
    var fType   = document.getElementById('cms-filter-type');

    var table = tigerDataTable('#cms-pages-table', {
        service: { module: 'cms', service: 'page', action: 'datatable' },
        order: [[5, 'desc']],
        language: { search: '', searchPlaceholder: 'Search content…' },
        // Toolbar filters ride along on every request (server-side scoping).
        extraData: function () {
            return { status: fStatus.value, type: fType.value };
        },
        columns: [
            { data: 'title', render: function (t, type, row) {
                return type !== 'display' ? t :
                    '<a href="/cms/page/edit/id/' + encodeURIComponent(row.page_id) + '" class="fw-semibold text-decoration-none">' + esc(t) + '</a>';
            } },
            { data: 'type', render: function (t, type) {
                return type !== 'display' ? t :
                    '<i class="fa-solid ' + (TYPE_ICON[t] || 'fa-file') + ' fa-fw text-body-secondary me-1"></i>' + esc(cap(t));
            } },
            { data: 'handle', render: function (t, type) {
                return type !== 'display' ? t : '<code class="text-body-secondary">' + esc(t) + '</code>';
            } },
            { data: 'locale', render: function (t, type) {
                return type !== 'display' ? t : '<span class="badge text-bg-light text-uppercase">' + esc(t) + '</span>';
            } },
            { data: 'status', render: function (t, type, row) {
                if (type !== 'display') { return t; }
                var h = '<span class="badge text-bg-' + (BADGE[t] || 'secondary') + '">' + esc(cap(t)) + '</span>';
                if (row.scheduled) { h += ' <span class="badge text-bg-info ms-1">Scheduled</span>'; }
                return h;
            } },
            { data: 'updated' },
            { data: null, orderable: false, searchable: false, className: 'text-end text-nowrap', render: function (t, type, row) {
                var html = '';
                if (row.can_edit) {
                    html += '<a href="/cms/page/edit/id/' + encodeURIComponent(row.page_id) + '" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fa-solid fa-pen"></i></a> ';
                    if (row.type === 'page') {
                        html += '<a href="/cms/page/design/id/' + encodeURIComponent(row.page_id) + '" class="btn btn-sm btn-outline-primary" title="Design visually"><i class="fa-solid fa-panorama"></i></a> ';
                    }
                }
                if (row.can_delete) {
                    html += '<button type="button" class="btn btn-sm btn-outline-danger" data-cms-delete="' + esc(row.page_id) + '" title="Delete"><i class="fa-solid fa-trash"></i></button>';
                } else {
                    html += '<button type="button" class="btn btn-sm btn-outline-danger" disabled title="Not permitted"><i class="fa-solid fa-trash"></i></button>';
                }
                return html || '<span class="text-body-secondary">—</span>';
            } }
        ]
    });

    // Re-query when a toolbar filter changes; Clear resets both.
    $('#cms-filter-status, #cms-filter-type').on('change', function () { table.ajax.reload(); });
    $('#cms-filter-clear').on('click', function () {
        fStatus.value = '';
        fType.value = '';
        table.ajax.reload();
    });

    // Theme templates: client-render with search + a cap (a theme may ship hundreds — Porto ~830).
    (function () {
        var all  = window.CMS_THEME_TEMPLATES || [];
        var grid = document.getElementById('tpl-grid');
        if (!grid || !all.length) { return; }
        var searchEl = document.getElementById('tpl-search');
        var moreBtn  = document.getElementById('tpl-more');
        var emptyEl  = document.getElementById('tpl-empty');
        var PAGE = 24, shown = PAGE, filtered = all;

        function card(t) {
            var actions = t.page_id
                ? '<a href="/cms/page/edit/id/' + encodeURIComponent(t.page_id) + '" class="btn btn-sm btn-outline-primary flex-grow-1"><i class="fa-solid fa-pen me-1"></i>Edit copy</a>'
                    + '<span class="badge text-bg-success-subtle text-success-emphasis border border-success-subtle text-nowrap">Customized</span>'
                : '<button type="button" class="btn btn-sm btn-primary flex-grow-1" data-theme-fork="' + esc(t.slug) + '"><i class="fa-solid fa-wand-magic-sparkles me-1"></i>Customize</button>';
            return '<div class="col-sm-6 col-lg-4"><div class="border rounded p-3 h-100 d-flex flex-column">'
                 + '<div class="fw-semibold text-truncate" title="' + esc(t.title) + '">' + esc(t.title) + '</div>'
                 + '<div class="small text-body-secondary mb-3 text-truncate"><code>/' + esc(t.slug) + '</code>'
                 +   (t.layout ? ' <span class="ms-1"><i class="fa-solid fa-table-columns fa-fw"></i> ' + esc(t.layout) + '</span>' : '') + '</div>'
                 + '<div class="mt-auto d-flex align-items-center gap-2">'
                 +   '<a href="/' + esc(t.slug) + '" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary" title="Preview"><i class="fa-solid fa-eye"></i></a>'
                 +   actions + '</div></div></div>';
        }
        function render() {
            var slice = filtered.slice(0, shown);
            grid.innerHTML = slice.map(card).join('');
            moreBtn.hidden  = shown >= filtered.length;
            moreBtn.textContent = 'Show more (' + (filtered.length - slice.length) + ')';
            emptyEl.hidden  = filtered.length > 0;
        }
        function apply() {
            var q = (searchEl.value || '').toLowerCase().trim();
            filtered = q ? all.filter(function (t) { return (t.title + ' ' + t.slug).toLowerCase().indexOf(q) > -1; }) : all;
            shown = PAGE; render();
        }
        var td;
        searchEl.addEventListener('input', function () { clearTimeout(td); td = setTimeout(apply, 150); });
        moreBtn.addEventListener('click', function () { shown += PAGE; render(); });
        render();
    })();

    // Customize a theme template: fork it into an editable page (server), then open the editor.
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-theme-fork]');
        if (!btn) { return; }
        var body = new URLSearchParams({ module: 'cms', service: 'page', method: 'forkTheme', slug: btn.getAttribute('data-theme-fork') });
        TigerButton.run(btn, function () {
            return fetch('/api', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: body }).then(function (r) { return r.json(); });
        }).then(function (res) {
            var url = (res && res.data && res.data.edit_url) || (res && res.redirect);
            if (res && res.result === 1 && url) { window.location = url; return; }
            (res && res.messages || []).forEach(function (m) { alert(m.message); });
        }).catch(function () { alert('Could not customize that template.'); });
    });

    // Soft-delete via /api, then reload just the table data (no page reload).
    $('#cms-pages-table tbody').on('click', '[data-cms-delete]', function () {
        if (!confirm('Delete this page? It is soft-deleted and can be recovered.')) { return; }
        var btn  = this;
        var body = new URLSearchParams({ module: 'cms', service: 'page', method: 'delete', page_id: this.getAttribute('data-cms-delete') });
        TigerButton.run(btn, function () {
            return fetch('/api', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: body })
                .then(function (r) { return r.json(); });
        })
            .then(function () { table.ajax.reload(null, false); })
            .catch(function () { table.ajax.reload(null, false); });
    });
});
</script>
