<script>
document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('cms-settings-form');
    var fb   = document.getElementById('cms-settings-feedback');

    function alertHtml(msg, cls) {
        var ctx = (cls === 'error') ? 'danger' : (cls || 'info');
        return '<div class="alert alert-' + ctx + ' alert-dismissible" role="alert">' + String(msg) +
               '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>';
    }
    document.getElementById('cms-settings-save').addEventListener('click', function () {
        fb.innerHTML = '';
        form.querySelectorAll('.is-invalid').forEach(function (e) { e.classList.remove('is-invalid'); });
        var fd = new URLSearchParams(new FormData(form));
        fd.set('module', 'cms'); fd.set('service', 'settings'); fd.set('method', 'save');
        fetch('/api', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd })
            .then(function (r) { return r.json().catch(function () { return {}; }); })
            .then(function (res) {
                if (res && res.result === 1) {
                    fb.innerHTML = alertHtml('Settings saved.', 'success');
                    return;
                }
                if (res && res.form) {
                    Object.keys(res.form).forEach(function (field) {
                        var input = form.querySelector('[name="' + field + '"]');
                        if (input) { input.classList.add('is-invalid'); }
                    });
                }
                (res && res.messages || []).forEach(function (m) { fb.innerHTML += alertHtml(m.message, m.class); });
                if (!res || !res.messages || !res.messages.length) { fb.innerHTML = alertHtml('Please fix the highlighted fields.', 'error'); }
            })
            .catch(function () { fb.innerHTML = alertHtml('Network error — please try again.', 'error'); });
    });

    // --- Session & security: live human-readable durations + dim the options when off ---
    function humanize(total) {
        total = Math.max(0, parseInt(total, 10) || 0);
        if (!total) { return '0 seconds'; }
        var units = [['year', 31536000], ['month', 2592000], ['day', 86400], ['hour', 3600], ['minute', 60]];
        var parts = [], rem = total;
        units.forEach(function (u) {
            var n = Math.floor(rem / u[1]);
            if (n > 0) { parts.push(n + ' ' + u[0] + (n > 1 ? 's' : '')); rem -= n * u[1]; }
        });
        if (rem > 0 && parts.length < 2) { parts.push(rem + ' second' + (rem > 1 ? 's' : '')); }
        return parts.join(', ');
    }
    function bindDuration(inputId, outId) {
        var i = document.getElementById(inputId), o = document.getElementById(outId);
        if (!i || !o) { return; }
        var upd = function () { o.textContent = '≈ ' + humanize(i.value); };
        i.addEventListener('input', upd); upd();
    }
    bindDuration('set-session-ttl', 'set-session-ttl-h');
    bindDuration('set-autologout-seconds', 'set-autologout-seconds-h');

    var alToggle = document.getElementById('set-autologout-enabled');
    var alOpts   = document.getElementById('set-autologout-opts');
    if (alToggle && alOpts) {
        // Dim only — the fields must still submit (they're required server-side), so we
        // don't disable them.
        var sync = function () { alOpts.classList.toggle('opacity-50', !alToggle.checked); };
        alToggle.addEventListener('change', sync); sync();
    }
});
</script>
