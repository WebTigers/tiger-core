/**
 * CMS Settings — the site name + the home page served at "/". ViewHelper-only form (the
 * view owns markup). Saving is an /api call to Cms_Service_Settings; the JSON response
 * drives the feedback. (Session/security moved to System settings.)
 */
$form = $this->form;
$el = function ($name) use ($form) { return $form->getElement($name); };
?>
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">CMS</h1>
        <p class="text-body-secondary mb-0">Your site's name and home page.</p>
    </div>
    <div class="text-nowrap">
        <button type="button" id="cms-settings-save" class="btn btn-primary"><i class="fa-solid fa-floppy-disk me-2"></i>Save</button>
    </div>
</div>

<div id="cms-settings-feedback"></div>

<form id="cms-settings-form" onsubmit="return false;" novalidate>
    <?= $el('_csrf') ?>
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header fw-semibold"><i class="fa-solid fa-globe me-2"></i>Site Settings</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label" for="<?= $this->escape($el('site_name')->getId()) ?>">Site name</label>
                        <?= $el('site_name') ?>
                        <div class="form-text">Shown in the site header and browser tab, and used as the default page title.</div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label" for="<?= $this->escape($el('home_page')->getId()) ?>">Home page</label>
                        <?= $el('home_page') ?>
                        <div class="form-text">Which page to serve at <code>/</code>. “Built-in landing page” keeps the default marketing page.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('cms-settings-form');
    var fb   = document.getElementById('cms-settings-feedback');

    document.getElementById('cms-settings-save').addEventListener('click', function () {
        var btn = this;
        fb.innerHTML = '';
        form.querySelectorAll('.is-invalid').forEach(function (e) { e.classList.remove('is-invalid'); });
        var fd = new URLSearchParams(new FormData(form));
        fd.set('module', 'cms'); fd.set('service', 'settings'); fd.set('method', 'save');
        TigerButton.run(btn, function () {
            return fetch('/api', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd })
                .then(function (r) { return r.json().catch(function () { return {}; }); });
        })
            .then(function (res) {
                if (res && res.result === 1) { TigerDOM.notify(fb, 'Settings saved.', { type: 'success' }); return; }
                if (res && res.form) {
                    Object.keys(res.form).forEach(function (field) {
                        var input = form.querySelector('[name="' + field + '"]');
                        if (input) { input.classList.add('is-invalid'); }
                    });
                }
                var msgs = (res && res.messages) || [];
                if (msgs.length) { fb.innerHTML = ''; msgs.forEach(function (m) { TigerDOM.notify(fb, m.message, { type: m.class, replace: false }); }); }
                else { TigerDOM.notify(fb, 'Please fix the highlighted fields.', { type: 'error' }); }
            })
            .catch(function () { TigerDOM.notify(fb, 'Network error — please try again.', { type: 'error' }); });
    });
});
</script>
