/**
 * PUMA admin header (MIT, Tiger-original).
 *
 * Brand + sidebar toggle, search, notifications, LANGUAGE switcher, light/dark
 * THEME switcher, and the user box. Rendered in the layout scope via render(),
 * so $this->themeAssets/escape are available. Behavior: assets/js/tiger.prefs.js
 * (vanilla, no jQuery) — the markup only supplies data-attributes.
 */
$auth     = Zend_Auth::getInstance();
$identity = $auth->hasIdentity() ? $auth->getIdentity() : null;
$userName = $identity->email    ?? 'Guest';
$userRole = $identity->role     ?? 'guest';
$orgName  = $identity->org_name ?? '';

// Current user's avatar (option tier → media → URL), else '' for the icon placeholder. The key is
// the profile module's avatar convention (`tiger.user.avatar`), referenced as a LITERAL so this
// core theme partial never imports a module class (ARCHITECTURE: core/theme depends on no module).
$userAvatar = '';
if ($identity && !empty($identity->user_id)) {
    try {
        $opt = new Tiger_Model_Option();
        // Display name overrides the email label (profile option, `tiger.user.display_name`); falls back to email.
        $dn = $opt->get(Tiger_Model_Option::SCOPE_USER, (string) $identity->user_id, 'tiger.user.display_name');
        if ($dn !== null && trim((string) $dn) !== '') { $userName = trim((string) $dn); }
        // Avatar (option → media → URL), else '' for the icon placeholder.
        $mediaId = $opt->get(Tiger_Model_Option::SCOPE_USER, (string) $identity->user_id, 'tiger.user.avatar');
        if ($mediaId) {
            $mediaRow = (new Tiger_Model_Media())->findById($mediaId);
            if ($mediaRow) { $userAvatar = (new Tiger_Model_Media())->url($mediaRow->toArray()); }
        }
    } catch (Throwable $e) { $userAvatar = ''; }
}

// ACL filter for module-registered header + user-menu items — hidden only when the role is denied a
// resource the ACL actually knows about (mirrors admin-menu.phtml).
$acl     = Zend_Registry::isRegistered('Zend_Acl') ? Zend_Registry::get('Zend_Acl') : null;
$allowed = function ($resource) use ($acl, $userRole) {
    if (empty($resource) || !$acl) { return true; }
    return $acl->has($resource) ? $acl->isAllowed($userRole, $resource) : true;
};
?>
<header class="tiger-header">

    <button class="btn btn-link text-body p-1" data-tiger-toggle="sidebar" aria-label="Toggle navigation">
        <i class="fa-solid fa-bars fa-lg"></i>
    </button>

    <a class="tiger-brand ms-1" href="/admin">
        <i class="fa-solid fa-paw"></i><span class="tiger-nav-label">Tiger</span>
    </a>

    <form class="tiger-search ms-3" action="/admin/search" role="search">
        <div class="input-group input-group-sm">
            <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-magnifying-glass text-secondary"></i></span>
            <input type="search" name="q" class="form-control border-start-0" placeholder="Search…" aria-label="Search">
        </div>
    </form>

    <div class="tiger-header-spacer"></div>

    <!-- Module-registered header actions (Tiger_Admin_Header) — ACL-filtered icon buttons. -->
    <?php foreach (Tiger_Admin_Header::items() as $hi): if (!$allowed($hi['resource'])) { continue; } ?>
        <a href="<?= $this->escape($hi['href']) ?>" class="btn btn-link text-body px-2"
           title="<?= $this->escape($hi['label']) ?>" aria-label="<?= $this->escape($hi['label']) ?>">
            <i class="fa-solid <?= $this->escape($hi['icon']) ?> fa-lg"></i>
        </a>
    <?php endforeach; ?>

    <!-- Notifications (demo content; wire to real feeds later) -->
    <div class="dropdown">
        <a href="#" class="btn btn-link text-body position-relative px-2" data-bs-toggle="dropdown" aria-label="Alerts">
            <i class="fa-solid fa-bell fa-lg"></i>
            <span class="position-absolute translate-middle badge rounded-pill bg-danger" style="top:.35rem;left:calc(100% - .35rem);font-size:.6rem;">3</span>
        </a>
        <div class="dropdown-menu dropdown-menu-end shadow p-0" style="min-width:290px;">
            <div class="dropdown-header d-flex justify-content-between"><span>Alerts</span><span class="badge text-bg-secondary">3</span></div>
            <a class="dropdown-item d-flex gap-2 py-2" href="#"><i class="fa-solid fa-triangle-exclamation text-warning mt-1"></i><span><strong>User locked</strong><br><small class="text-secondary">15 minutes ago</small></span></a>
            <a class="dropdown-item d-flex gap-2 py-2" href="#"><i class="fa-solid fa-signal text-success mt-1"></i><span><strong>Connection restored</strong><br><small class="text-secondary">1 hour ago</small></span></a>
            <div class="dropdown-divider"></div>
            <a class="dropdown-item text-center small py-2" href="#">View all</a>
        </div>
    </div>

    <!-- Language + theme switchers (shared partials, also used by the public header) -->
    <?= $this->render('_partials/lang-switcher.phtml') ?>
    <?= $this->render('_partials/theme-switcher.phtml') ?>

    <!-- Skin switcher (prototyping: live skin preview) -->
    <?= $this->render('_partials/skin-switcher.phtml') ?>

    <!-- User box -->
    <div class="dropdown ms-1">
        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none text-body" data-bs-toggle="dropdown">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle overflow-hidden flex-shrink-0" style="width:34px;height:34px;">
                <img id="header-avatar-img" src="<?= $this->escape($userAvatar) ?>" alt=""
                     class="w-100 h-100 <?= $userAvatar === '' ? 'd-none' : '' ?>" style="object-fit:cover;">
                <i id="header-avatar-icon" class="fa-solid fa-user text-secondary <?= $userAvatar === '' ? '' : 'd-none' ?>"></i>
            </span>
            <span class="d-none d-md-block text-start lh-sm">
                <span id="header-user-name" data-email="<?= $this->escape($identity->email ?? '') ?>" class="d-block small fw-semibold"><?= $this->escape($userName) ?></span>
                <span class="d-block text-secondary" style="font-size:.72rem;"><?= $this->escape($orgName ?: ucfirst($userRole)) ?></span>
            </span>
            <i class="fa-solid fa-chevron-down small text-secondary d-none d-md-inline"></i>
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow">
            <li><a class="dropdown-item" href="/user/profile"><i class="fa-solid fa-id-badge me-2 fa-fw"></i>My Profile</a></li>
            <li><a class="dropdown-item" href="/auth/security"><i class="fa-solid fa-shield-halved me-2 fa-fw"></i>Two-Factor Auth</a></li>
            <?php foreach (Tiger_Admin_UserMenu::items() as $mi): if (!$allowed($mi['resource'])) { continue; } ?>
                <li><a class="dropdown-item" href="<?= $this->escape($mi['href']) ?>"><i class="fa-solid <?= $this->escape($mi['icon']) ?> me-2 fa-fw"></i><?= $this->escape($mi['label']) ?></a></li>
            <?php endforeach; ?>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/auth/lock"><i class="fa-solid fa-lock me-2 fa-fw"></i>Lock Screen</a></li>
            <li><a class="dropdown-item" href="/logout"><i class="fa-solid fa-power-off me-2 fa-fw"></i>Sign Out</a></li>
        </ul>
    </div>

</header>

<script>
// Live-update the header avatar the moment it changes elsewhere (e.g. the profile Basic tab),
// no reload. Any avatar source fires window 'tiger:avatar-changed' with { url } (null = removed).
window.addEventListener('tiger:avatar-changed', function (e) {
    var img = document.getElementById('header-avatar-img');
    var ico = document.getElementById('header-avatar-icon');
    if (!img || !ico) { return; }
    var url = e.detail && e.detail.url;
    if (url) { img.src = url; img.classList.remove('d-none'); ico.classList.add('d-none'); }
    else     { img.classList.add('d-none'); ico.classList.remove('d-none'); }
});
// Live-update the header label when the display name changes (Basic tab); falls back to the email.
window.addEventListener('tiger:display-name-changed', function (e) {
    var el = document.getElementById('header-user-name');
    if (!el) { return; }
    var name = e.detail && e.detail.name;
    el.textContent = name || el.getAttribute('data-email') || 'User';
});
</script>
