<?php
/**
 * PUMA skin switcher (MIT, Tiger-original).
 *
 * A live skin picker — a prototyping tool so devs can preview each skin instantly.
 * Lists the skins found on disk ($this->skins, globbed by _initTheme) and, on click,
 * tiger.prefs.js hot-swaps the #tiger-skin stylesheet + sets the `tiger_skin` cookie
 * (NO reload). Deliberately Font-Awesome-free (color-swatch dots, inline SVG) so it
 * works on the header AND on bare public pages.
 *
 * Rendered in the layout scope via render(), so $this->skins/$this->skin flow in.
 */
$skins  = $this->skins ?? array();
$active = $this->skin  ?? '';
if (!$skins) { return; }

// name => [label, Bootswatch origin, primary swatch]. Unknown skins fall back to
// a title-cased name with a neutral swatch.
$catalog = array(
    'puma'    => array('Puma',    'Zephyr', '#3459e6'),
    'jaguar'  => array('Jaguar',  'Flatly', '#2c3e50'),
    'tabby'   => array('Tabby',   'United', '#e95420'),
    'cheetah' => array('Cheetah', 'Custom', '#f59e0b'),
);
$meta = function ($s) use ($catalog) {
    return $catalog[$s] ?? array(ucfirst($s), '', '#6c757d');
};
$activeLabel = $meta($active)[0];
?>
<div class="dropdown tiger-skin-switcher">
    <a href="#" class="btn btn-link text-body text-decoration-none px-2 d-flex align-items-center gap-2"
       data-bs-toggle="dropdown" aria-label="Skin" title="Skin (live preview)">
        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="9" cy="9" r="5.5" fill="#3459e6"></circle>
            <circle cx="15" cy="15" r="5.5" fill="#e95420" opacity=".85"></circle>
        </svg>
        <span id="tiger-skin-label" class="small d-none d-lg-inline"><?= $this->escape($activeLabel) ?></span>
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow">
        <li><h6 class="dropdown-header">Skin — live preview</h6></li>
<?php foreach ($skins as $s): $m = $meta($s); ?>
        <li>
            <a class="dropdown-item tiger-skin-switch d-flex align-items-center justify-content-between<?= $s === $active ? ' active' : '' ?>"
               href="#" data-skin="<?= $this->escape($s) ?>" data-label="<?= $this->escape($m[0]) ?>">
                <span class="d-flex align-items-center">
                    <span class="rounded-circle me-2 flex-shrink-0" style="width:12px;height:12px;background:<?= $this->escape($m[2]) ?>;box-shadow:0 0 0 1px rgba(128,128,128,.35);"></span>
                    <?= $this->escape($m[0]) ?>
                </span>
<?php if (!empty($m[1])): ?>
                <span class="badge text-bg-secondary ms-3" style="font-size:.6rem;"><?= $this->escape($m[1]) ?></span>
<?php endif; ?>
            </a>
        </li>
<?php endforeach; ?>
    </ul>
</div>
