/**
 * Cookie-consent banner (PUMA) — GDPR + CCPA in ONE banner, ONE Accept. Self-checking: renders
 * nothing unless Tiger_Consent::showBanner() is true. Accept writes the consent cookie ('all') and
 * reloads so consent-gated trackers (GA, …) load; "Necessary only" writes 'none' — which is also the
 * California opt-out of sale/sharing. When a Global Privacy Control signal is present we say so and
 * you're already opted out (honored server-side by Tiger_Consent); an explicit Accept still wins.
 * Bootstrap + --bs-* tokens, so it restyles with the theme + skin.
 */
if (!class_exists('Tiger_Consent') || !Tiger_Consent::showBanner()) {
    return;
}
$c   = Tiger_Consent::settings();
$gpc = !empty($c['gpc']) && !empty($c['honor_gpc']);
?>
<div id="tiger-consent" class="fixed-bottom p-3" role="dialog" aria-live="polite" aria-label="Cookie consent">
    <div class="container">
        <div class="card border-0 shadow-lg">
            <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-3 p-3 p-md-4">
                <div class="flex-grow-1 small text-body-secondary">
                    <i class="fa-solid fa-cookie-bite text-primary me-2"></i>
                    <?= $this->escape($c['message']) ?>
<?php if ($c['policy_url'] !== ''): ?>
                    <a href="<?= $this->escape($c['policy_url']) ?>" class="text-decoration-none">Learn more</a>.
<?php endif; ?>
                    <!-- Global Privacy Control acknowledgment (server-detected here; JS reveals it too). -->
                    <div id="tiger-consent-gpc" class="text-success mt-1<?= $gpc ? '' : ' d-none' ?>">
                        <i class="fa-solid fa-shield-halved me-1"></i>Global Privacy Control detected — you're opted out of analytics &amp; sharing.
                    </div>
<?php if (!empty($c['ccpa_notice'])): ?>
                    <div class="text-body-secondary mt-1" style="font-size:.85em;"><?= $this->escape($c['ccpa_notice']) ?></div>
<?php endif; ?>
                </div>
                <div class="d-flex gap-2 flex-shrink-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-consent="reject"><?= $this->escape($c['reject_label']) ?></button>
                    <button type="button" class="btn btn-primary btn-sm" data-consent="accept"><?= $this->escape($c['accept_label']) ?></button>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
(function () {
    var bar = document.getElementById('tiger-consent');
    if (!bar) { return; }
    // Belt-and-suspenders: if the browser exposes GPC via JS but a proxy stripped the Sec-GPC header,
    // still surface the opt-out acknowledgment.
    if (navigator.globalPrivacyControl === true) {
        var g = document.getElementById('tiger-consent-gpc');
        if (g) { g.classList.remove('d-none'); }
    }
    function setCookie(v) {
        document.cookie = 'tiger_consent=' + v + '; path=/; max-age=31536000; SameSite=Lax';
    }
    bar.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-consent]');
        if (!btn) { return; }
        if (btn.getAttribute('data-consent') === 'accept') {
            setCookie('all');           // explicit opt-in — overrides any GPC signal for this visitor
            location.reload();          // reload so consent-gated tags (e.g. GA) load this visit
        } else {
            setCookie('none');          // GDPR decline == CCPA opt-out of sale/sharing
            bar.parentNode.removeChild(bar);
        }
    });
})();
</script>
