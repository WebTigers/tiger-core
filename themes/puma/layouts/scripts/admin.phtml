<?php
/**
 * PUMA — Admin shell layout (MIT, Tiger-original).
 *
 * The application chrome: fixed header, collapsible left sidebar, main content,
 * and an OPTIONAL right aside. Written from scratch on Bootstrap 5.3 — NO paid
 * template. Light/dark is Bootstrap's native `data-bs-theme`; components are stock
 * Bootstrap; only the shell layout is our own CSS (assets/admin.css). Asset URLs go
 * through $this->asset() for cache-busting.
 *
 * A controller opts in with `$this->_helper->layout()->setLayout('admin')`.
 * View vars honored:
 *   $this->rightAside (bool)  render the right aside rail
 *   $this->nav        (array) sidebar nav tree (see _partials/admin-menu.phtml)
 *
 * Shell partials are pulled with render() (NOT partial()) so the layout's view
 * vars — themeAssets, skin, nav — flow into them; partial() clears the scope.
 */

// No-FOUC: resolve the theme cookie server-side so the FIRST paint is already
// correct for explicit light/dark. 'browser' starts light here and is corrected
// client-side by theme-init.js (matchMedia) before stylesheets apply.
$_pref = $_COOKIE['tiger_theme'] ?? 'browser';
if (!in_array($_pref, ['browser', 'light', 'dark'], true)) { $_pref = 'browser'; }
$_mode = ($_pref === 'dark') ? 'dark' : 'light';
$_lang = defined('LANG') ? LANG : 'en';
$_hasAside = !empty($this->rightAside);
?><!doctype html>
<html lang="<?= $this->escape($_lang) ?>" data-bs-theme="<?= $_mode ?>" class="tiger-admin<?= $_hasAside ? ' has-right-aside' : '' ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= $this->escape($this->title ?? 'Tiger Admin') ?></title>

    <!-- No-FOUC theme resolver: MUST run before the stylesheets below paint. -->
    <script src="<?= $this->asset($this->themeAssets . '/js/theme-init.js') ?>"></script>

    <!-- Vendored fonts + icons (no CDN): Inter + Font Awesome Free. -->
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/fonts/inter/inter.css') ?>">
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/fontawesome/css/all.min.css') ?>">

    <!-- Cascade (last wins): base Bootstrap → theme defaults → active skin. -->
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/css/bootstrap.min.css') ?>">
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/default.css') ?>">
<?php if (!empty($this->skin)): ?>
    <link id="tiger-skin" rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/skins/' . $this->skin . '.css') ?>">
<?php endif; ?>
    <!-- The admin shell chrome (our MIT layout CSS — Bootstrap ships no app shell). -->
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/admin.css') ?>">
<?php if (!empty($this->useDataTables)): ?>
    <!-- DataTables (Bootstrap 5), loaded only for screens that opt in ($this->useDataTables). -->
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/datatables/dataTables.bootstrap5.min.css') ?>">
<?php endif; ?>
</head>
<body>
<div class="tiger-shell">

    <?= $this->render('_partials/admin-header.phtml') ?>

    <div class="tiger-body">
        <?= $this->render('_partials/admin-sidebar-left.phtml') ?>

        <main class="tiger-content" role="main">
            <?= $this->layout()->content ?>
        </main>

<?php if ($_hasAside): ?>
        <?= $this->render('_partials/admin-sidebar-right.phtml') ?>
<?php endif; ?>
    </div>

</div>

<!-- Backdrop for the off-canvas sidebar on mobile. -->
<div class="tiger-backdrop" data-tiger-toggle="sidebar"></div>

<script src="<?= $this->asset($this->themeAssets . '/js/bootstrap.bundle.min.js') ?>"></script>
<?php if (!empty($this->useDataTables)): ?>
<!-- jQuery + DataTables: the admin's one jQuery dependency (data grids only); the
     public theme and the rest of the admin stay vanilla. Order: jQuery → core → BS5. -->
<script src="<?= $this->asset($this->themeAssets . '/vendor/jquery/jquery.min.js') ?>"></script>
<script src="<?= $this->asset($this->themeAssets . '/vendor/datatables/dataTables.min.js') ?>"></script>
<script src="<?= $this->asset($this->themeAssets . '/vendor/datatables/dataTables.bootstrap5.min.js') ?>"></script>
<!-- Tiger's shared grid helper: /api-sourced DataTables + envelope unwrap. -->
<script src="<?= $this->asset($this->themeAssets . '/js/tiger.datatable.js') ?>"></script>
<?php endif; ?>
<script src="<?= $this->asset($this->themeAssets . '/js/tiger.prefs.js') ?>"></script>
</body>
</html>
