<?php
/**
 * PUMA layout — the page chrome.
 *
 * CSS load order (cascade, last wins): bootstrap → default → active skin.
 * Asset base `$this->themeAssets` (default: /_theme) is the docroot symlink to this
 * theme's assets/ dir. Theme + skin are chosen by the app Bootstrap (config now,
 * per-org later).
 *
 * Theme mode: honors the `tiger_theme` cookie (browser|light|dark) server-side so
 * the first paint is correct; theme-init.js finishes 'browser' via matchMedia
 * before CSS applies (same mechanism as the admin shell).
 */
$_pref = $_COOKIE['tiger_theme'] ?? 'browser';
if (!in_array($_pref, ['browser', 'light', 'dark'], true)) { $_pref = 'browser'; }
$_mode = ($_pref === 'dark') ? 'dark' : 'light';
$_lang = defined('LANG') ? LANG : 'en';
?><!doctype html>
<html lang="<?= $this->escape($_lang) ?>" data-bs-theme="<?= $_mode ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= $this->escape($this->title ?? 'Tiger') ?></title>

    <!-- No-FOUC theme resolver: MUST run before the stylesheets below paint. -->
    <script src="<?= $this->themeAssets ?>/js/theme-init.js"></script>

    <link rel="stylesheet" href="<?= $this->themeAssets ?>/css/bootstrap.min.css">
    <link rel="stylesheet" href="<?= $this->themeAssets ?>/default.css">
<?php if (!empty($this->skin)): ?>
    <link id="tiger-skin" rel="stylesheet" href="<?= $this->themeAssets ?>/skins/<?= $this->escape($this->skin) ?>.css">
<?php endif; ?>
</head>
<body>
<?= $this->layout()->content ?>

<?php if (APPLICATION_ENV !== 'production' && !empty($this->skins)): ?>
<!-- Floating skin switcher — a prototyping affordance so devs can preview skins on
     any page (public pages have no header). Non-production only; the admin header
     carries the same control. -->
<div class="position-fixed bottom-0 end-0 m-3 bg-body border rounded-pill shadow-sm" style="z-index:1050;">
    <?= $this->render('_partials/skin-switcher.phtml') ?>
</div>
<?php endif; ?>

<script src="<?= $this->themeAssets ?>/js/bootstrap.bundle.min.js"></script>
<script src="<?= $this->themeAssets ?>/js/tiger.prefs.js"></script>
</body>
</html>
