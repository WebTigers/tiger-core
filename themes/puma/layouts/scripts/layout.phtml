/**
 * PUMA layout â€” the page chrome.
 *
 * CSS load order (cascade, last wins): bootstrap â†’ default â†’ active skin.
 * Asset base `$this->themeAssets` (default: /_theme) is the docroot symlink to this
 * theme's assets/ dir. Theme + skin are chosen by the app Bootstrap (config now,
 * per-org later). Asset URLs go through $this->asset() for cache-busting.
 *
 * Theme mode: honors the `tiger_theme` cookie (browser|light|dark) server-side so
 * the first paint is correct; theme-init.js finishes 'browser' via matchMedia
 * before CSS applies (same mechanism as the admin shell).
 */
$_pref = $_COOKIE['tiger_theme'] ?? 'browser';
if (!in_array($_pref, ['browser', 'light', 'dark'], true)) { $_pref = 'browser'; }
$_mode = ($_pref === 'dark') ? 'dark' : 'light';
$_lang = defined('LANG') ? LANG : 'en';
?><!doctype html>
<html lang="<?= $this->escape($_lang) ?>" data-bs-theme="<?= $_mode ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><?= $this->escape($this->title ?? ($this->siteName ?? 'Tiger')) ?></title>

    <!-- No-FOUC theme resolver: MUST run before the stylesheets below paint. -->
    <script src="<?= $this->asset($this->themeAssets . '/js/theme-init.js') ?>"></script>

    <!-- Vendored fonts + icons (no CDN): Inter + Font Awesome Free. -->
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/fonts/inter/inter.css') ?>">
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/vendor/fontawesome/css/all.min.css') ?>">

    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/css/bootstrap.min.css') ?>">
    <link rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/default.css') ?>">
<?php if (!empty($this->skin)): ?>
    <link id="tiger-skin" rel="stylesheet" href="<?= $this->asset($this->themeAssets . '/skins/' . $this->skin . '.css') ?>">
<?php endif; ?>
<?= $this->codeInject('head') ?>
</head>
<body>
<?= $this->render('_partials/public-header.phtml') ?>

<main>
<?= $this->layout()->content ?>
</main>

<?= $this->render('_partials/public-footer.phtml') ?>

<script src="<?= $this->asset($this->themeAssets . '/js/bootstrap.bundle.min.js') ?>"></script>
<script src="<?= $this->asset($this->themeAssets . '/js/tiger.prefs.js') ?>"></script>
<?= $this->codeInject('footer') ?>
</body>
</html>
