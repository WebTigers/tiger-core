#!/usr/bin/env php
<?php
/**
 * The `tiger` console.
 *
 * Installed as vendor/bin/tiger in a Tiger app (composer "bin"). Run it from the
 * app root: `vendor/bin/tiger <command>`.
 *
 * It boots the app through Tiger_Application::boot() — the SAME path a web request
 * takes, minus dispatch — so every command sees the identical constants, config
 * cascade, and DB adapter. No separate CLI bootstrap to drift out of sync.
 */

// --- 1) Locate the app root: nearest ancestor of CWD holding application/configs ---
$root  = getenv('TIGER_APP_ROOT') ?: getcwd();
$probe = $root;
while ($probe !== '' && $probe !== '/' && !is_dir($probe . '/application/configs')) {
    $probe = dirname($probe);
}
if (is_dir($probe . '/application/configs')) {
    $root = $probe;
}
if (!is_file($root . '/vendor/autoload.php')) {
    fwrite(STDERR, "tiger: run this from a Tiger app root (no vendor/autoload.php found)\n");
    exit(1);
}

define('APPLICATION_ROOT', $root);
require $root . '/vendor/autoload.php';

// --- 2) Boot WITHOUT dispatching (constants + config + DB adapter) ---
(new Tiger_Application($root))->boot();

$log = function ($message) { fwrite(STDOUT, $message . "\n"); };

/** The default DB adapter, or a clear error if none is configured. */
function tiger_db()
{
    $db = Zend_Db_Table_Abstract::getDefaultAdapter();
    if (!$db) {
        fwrite(STDERR, "tiger: no database configured — set tiger.db.* in application/configs/local.ini\n");
        exit(1);
    }
    return $db;
}

/** Migration dirs, in precedence order: core (package) -> app -> each module. */
function tiger_migration_paths()
{
    $paths = [TIGER_CORE_PATH . '/migrations', APPLICATION_PATH . '/migrations'];
    foreach (glob(MODULES_PATH . '/*/migrations') ?: [] as $modMigrations) {
        $paths[] = $modMigrations;
    }
    return $paths;
}

/** Parse `--key=value` flags from argv into an assoc array. */
function tiger_flags($argv)
{
    $out = [];
    foreach ($argv as $arg) {
        if (preg_match('/^--([a-zA-Z_]+)=(.*)$/', $arg, $m)) {
            $out[$m[1]] = $m[2];
        }
    }
    return $out;
}

/** Prompt for a line of input. */
function tiger_prompt($label)
{
    fwrite(STDOUT, "  $label: ");
    return trim((string) fgets(STDIN));
}

/** Prompt for a secret with terminal echo off (falls back to visible if no TTY). */
function tiger_prompt_secret($label)
{
    fwrite(STDOUT, "  $label: ");
    $canHide = strtoupper(substr(PHP_OS, 0, 3)) !== 'WIN' && function_exists('shell_exec');
    if ($canHide) { shell_exec('stty -echo 2>/dev/null'); }
    $value = trim((string) fgets(STDIN));
    if ($canHide) { shell_exec('stty echo 2>/dev/null'); fwrite(STDOUT, "\n"); }
    return $value;
}

// --- 3) Dispatch the subcommand ---
$cmd = isset($argv[1]) ? $argv[1] : 'help';

switch ($cmd) {
    case 'migrate':
        (new Tiger_Db_Migrator(tiger_db(), tiger_migration_paths()))->migrate($log);
        break;

    case 'migrate:status':
        foreach ((new Tiger_Db_Migrator(tiger_db(), tiger_migration_paths()))->status() as $version => $s) {
            printf("  [%s] %s_%s\n", $s['applied'] ? 'x' : ' ', $version, $s['name']);
        }
        break;

    case 'migrate:rollback':
        $steps = isset($argv[2]) ? (int) $argv[2] : 1;
        (new Tiger_Db_Migrator(tiger_db(), tiger_migration_paths()))->rollback($steps, $log);
        break;

    case 'install:secrets':
        // Generate the install's random secrets (app encryption key + password pepper)
        // into local.ini if missing. Idempotent; never rotates an existing secret.
        try {
            $made = Tiger_Install::provisionSecrets(APPLICATION_PATH . '/configs/local.ini');
            if ($made) {
                echo "  \xE2\x9C\x93 Provisioned into application/configs/local.ini:\n";
                foreach ($made as $k) { echo "    - {$k}\n"; }
            } else {
                echo "  All secrets already set — nothing to do.\n";
            }
        } catch (Throwable $e) {
            fwrite(STDERR, "  install:secrets failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'install:storage':
        // Create the writable runtime dirs (storage/cache/{code}, storage/media, public asset
        // dirs). Idempotent; safe to re-run. chown to the web-server user/group after if the
        // installer runs as a different user.
        try {
            $root = defined('APPLICATION_ROOT') ? APPLICATION_ROOT : dirname(APPLICATION_PATH);
            $made = Tiger_Install::provisionStorage($root);
            if ($made) {
                echo "  \xE2\x9C\x93 Created writable runtime dirs (chown to the web user/group if needed):\n";
                foreach ($made as $d) { echo "    - {$d}\n"; }
            } else {
                echo "  All runtime dirs already exist — nothing to do.\n";
            }
        } catch (Throwable $e) {
            fwrite(STDERR, "  install:storage failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'link:assets':
        // (Re)create the webroot's _theme/_tiger symlinks — the failsafe way to wire assets on
        // any host (recreate links, never copy). --webroot for the split layout (cPanel:
        // ~/public_html); defaults to <app root>/public (co-located). --theme (default puma).
        $flags   = tiger_flags($argv);
        $webroot = isset($flags['webroot']) ? $flags['webroot'] : (APPLICATION_ROOT . '/public');
        $theme   = isset($flags['theme']) ? $flags['theme'] : 'puma';
        try {
            $made = Tiger_Install::linkPublicAssets($webroot, APPLICATION_ROOT, $theme);
            foreach ($made as $name => $target) {
                echo "  \xE2\x9C\x93 {$webroot}/{$name} -> {$target}\n";
            }
        } catch (Throwable $e) {
            fwrite(STDERR, "  link:assets failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'install:admin':
        // Create the founding org + owner. Non-interactive via flags
        // (--email= --password= --org= [--username=] [--slug=] [--role=]); prompts for anything missing.
        tiger_db();
        // Mint the install secrets (crypto key + pepper) into local.ini. The founding
        // password is hashed before this process reloads config, so it starts unpeppered
        // and upgrades to the peppered scheme on first login (verifyPassword migration).
        try { Tiger_Install::provisionSecrets(APPLICATION_PATH . '/configs/local.ini'); } catch (Throwable $e) {}
        try { Tiger_Install::provisionStorage(defined('APPLICATION_ROOT') ? APPLICATION_ROOT : dirname(APPLICATION_PATH)); } catch (Throwable $e) {}
        $flags = tiger_flags($argv);
        $email = isset($flags['email']) ? $flags['email'] : tiger_prompt('Admin email');
        $org   = isset($flags['org'])   ? $flags['org']   : tiger_prompt('Organization name');
        $slug  = isset($flags['slug'])  ? $flags['slug']  : null;
        $role  = isset($flags['role'])  ? $flags['role']  : 'developer';   // god by default: a fresh install needs full access
        $username = isset($flags['username']) ? $flags['username'] : null;  // optional display username
        $pass  = isset($flags['password']) ? $flags['password'] : tiger_prompt_secret('Password (min 8)');
        try {
            $r = Tiger_Install::createOwner($email, $pass, $org, $slug, $role, $username);
            echo "\n  \xE2\x9C\x93 Admin created.\n";
            echo "    email   : {$r['email']}\n";
            if (!empty($r['username'])) { echo "    username: {$r['username']}\n"; }
            echo "    org     : {$r['org']}  ({$r['slug']})\n";
            echo "    role    : {$r['role']}\n";
            echo "    user_id : {$r['user_id']}\n";
            echo "    org_id  : {$r['org_id']}\n";
            echo "\n  Sign in at /auth/login\n\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  install:admin failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'module:install':
        // Install a module from a PUBLIC GitHub repo. Usage: module:install <url> [ref]
        tiger_db();
        $url = isset($argv[2]) ? $argv[2] : '';
        $ref = isset($argv[3]) ? $argv[3] : null;
        if ($url === '') { fwrite(STDERR, "  usage: module:install <github-url> [ref]\n"); exit(1); }
        try {
            $r = Tiger_Module_Installer::installFromUrl($url, $ref);
            echo "  \xE2\x9C\x93 Installed {$r['slug']}" . (!empty($r['version']) ? " v{$r['version']}" : '')
                . (!empty($r['ref']) ? " ({$r['ref']})" : '') . " — active.\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  module:install failed: " . $e->getMessage() . "\n"); exit(1);
        }
        break;

    case 'module:remove':
        // Remove an installer-managed module (files + assets + registry row). Usage: module:remove <slug>
        tiger_db();
        $slug = isset($argv[2]) ? $argv[2] : '';
        if ($slug === '') { fwrite(STDERR, "  usage: module:remove <slug>\n"); exit(1); }
        try {
            Tiger_Module_Installer::remove($slug);
            echo "  \xE2\x9C\x93 Removed {$slug}.\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  module:remove failed: " . $e->getMessage() . "\n"); exit(1);
        }
        break;

    case 'module:list':
        tiger_db();
        $state = (new Tiger_Model_Module())->bySlugMap();
        foreach (Tiger_Module_Discovery::all() as $slug => $m) {
            $row    = isset($state[$slug]) ? $state[$slug] : null;
            $active = $row ? ((int) $row->active === 1) : true;
            $src    = $row ? $row->source : ($m['area'] === 'core' ? 'bundled' : 'custom');
            printf("  [%s] %-18s %-11s %s\n", $active ? 'x' : ' ', $slug, $src, $m['version'] ?: '');
        }
        break;

    case 'module:activate':
    case 'module:deactivate':
        tiger_db();
        $slug = isset($argv[2]) ? $argv[2] : '';
        $on   = ($cmd === 'module:activate');
        if ($slug === '') { fwrite(STDERR, "  usage: {$cmd} <slug>\n"); exit(1); }
        if (!$on && in_array($slug, ['default', 'system', 'access'], true)) { fwrite(STDERR, "  {$slug} is protected.\n"); exit(1); }
        if ($on) {
            // Convenience alert (never a block): required modules that aren't active.
            $missing = Tiger_Module_Dependency::missing($slug);
            if ($missing) { echo "  \xE2\x9A\xA0 {$slug} requires: " . implode(', ', $missing) . " (activate them too)\n"; }
            (new Tiger_Model_Module())->setActive($slug, $on);
            Tiger_Module_Installer::publishAssets($slug);   // symlink public/_modules/<slug> if it has assets/
        } else {
            $dependents = Tiger_Module_Dependency::dependents($slug);
            if ($dependents) { echo "  \xE2\x9A\xA0 still required by: " . implode(', ', $dependents) . " (deactivating anyway)\n"; }
            (new Tiger_Model_Module())->setActive($slug, $on);
            Tiger_Module_Installer::unpublishAssets($slug);
        }
        echo "  \xE2\x9C\x93 {$slug} " . ($on ? 'activated' : 'deactivated') . ".\n";
        break;

    case 'crypto:rotate-key':
        // New encryption key; the old one is retained (tiger.crypto.key_retired) so
        // existing ciphertext still decrypts until crypto:rekey re-encrypts it.
        try {
            Tiger_Install::rotateSecret('tiger.crypto.key', 'tiger.crypto.key_retired',
                Tiger_Crypto::generateKey(), APPLICATION_PATH . '/configs/local.ini');
            echo "  \xE2\x9C\x93 Crypto key rotated (old key kept in tiger.crypto.key_retired).\n";
            echo "    Next: vendor/bin/tiger crypto:rekey            (re-encrypt stored secrets)\n";
            echo "    Then: vendor/bin/tiger secrets:drop-retired crypto\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  crypto:rotate-key failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'crypto:rekey':
        // Re-encrypt every stored reversible secret under the CURRENT key (lossless).
        tiger_db();
        try {
            $r = (new Tiger_Model_UserCredential())->rekeyTotpSecrets();
            echo "  Re-encrypted {$r['rekeyed']} secret(s) under the current key"
               . ($r['failed'] ? ", {$r['failed']} could not be decrypted" : "") . ".\n";
            echo "    You may now remove the old key: vendor/bin/tiger secrets:drop-retired crypto\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  crypto:rekey failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'security:rotate-pepper':
        // New pepper; the old one is retained (tiger.security.pepper_retired). One-way
        // hashes can't be rekeyed, so passwords re-pepper lazily on each next login.
        try {
            Tiger_Install::rotateSecret('tiger.security.pepper', 'tiger.security.pepper_retired',
                Tiger_Security::generatePepper(), APPLICATION_PATH . '/configs/local.ini');
            echo "  \xE2\x9C\x93 Pepper rotated (old pepper kept in tiger.security.pepper_retired).\n";
            echo "    Passwords re-pepper on each user's NEXT login (one-way hashes can't be rekeyed).\n";
            echo "    Once everyone has turned over (force-reset stragglers):\n";
            echo "      vendor/bin/tiger secrets:drop-retired pepper\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  security:rotate-pepper failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'secrets:drop-retired':
        // Remove retired secret(s) after a rotation has fully migrated (crypto|pepper|all).
        $which = (isset($argv[2]) && in_array($argv[2], ['crypto', 'pepper', 'all'], true)) ? $argv[2] : 'all';
        try {
            $dropped = Tiger_Install::dropRetired($which, APPLICATION_PATH . '/configs/local.ini');
            echo "  Cleared: " . implode(', ', $dropped) . "\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  secrets:drop-retired failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'make:module':
        // Scaffold a new application module (positional name, --name=, or prompt).
        $flags = tiger_flags($argv);
        $name  = isset($flags['name']) ? $flags['name']
               : ((isset($argv[2]) && strpos($argv[2], '--') !== 0) ? $argv[2] : tiger_prompt('Module name (lowercase, e.g. billing)'));
        try {
            $created = Tiger_Generator_Module::generate($name, APPLICATION_PATH . '/modules');
            $n = strtolower(trim($name));
            echo "\n  \xE2\x9C\x93 Module '{$n}' created:\n";
            foreach ($created as $file) {
                echo "    " . str_replace(APPLICATION_ROOT . '/', '', $file) . "\n";
            }
            echo "\n  It auto-registers (module scanning) — no wiring needed.\n";
            echo "    - visit  /{$n}/   (allowed to authenticated users; edit configs/acl.ini)\n";
            echo "    - call   POST /api  {\"module\":\"{$n}\",\"service\":\"example\",\"method\":\"ping\"}\n";
            echo "    - migrations go in application/modules/{$n}/migrations (run: vendor/bin/tiger migrate)\n\n";
        } catch (Throwable $e) {
            fwrite(STDERR, "  make:module failed: " . $e->getMessage() . "\n");
            exit(1);
        }
        break;

    case 'version':
        echo 'Tiger Core ' . Tiger_Version::VERSION . "\n";
        break;

    case 'help':
    default:
        echo "tiger — Tiger platform console\n\n";
        echo "Usage: vendor/bin/tiger <command>\n\n";
        echo "  migrate                Apply pending migrations (core + app + modules)\n";
        echo "  migrate:status         Show applied [x] / pending [ ] migrations\n";
        echo "  migrate:rollback [n]   Reverse the last n migrations (default 1)\n";
        echo "  install:secrets        Generate the install's random secrets (app encryption key +\n";
        echo "                         password/code pepper) into local.ini if missing (idempotent)\n";
        echo "  install:storage        Create the writable runtime dirs (storage/cache, media, public\n";
        echo "                         asset dirs) — idempotent; chown to the web user after if needed\n";
        echo "  link:assets            (Re)create the webroot's _theme/_tiger symlinks (failsafe asset\n";
        echo "                         wiring) — [--webroot=DIR (cPanel: ~/public_html)] [--theme=puma]\n";
        echo "  install:admin          Create the founding org + owner (also provisions secrets;\n";
        echo "                         --email= --password= --org= [--username=] [--slug=] [--role=developer])\n";
        echo "  crypto:rotate-key      Rotate the app encryption key (old kept as retired)\n";
        echo "  crypto:rekey           Re-encrypt stored secrets under the current key (lossless)\n";
        echo "  security:rotate-pepper Rotate the password/code pepper (re-peppers on next login)\n";
        echo "  secrets:drop-retired [crypto|pepper|all]  Remove retired secrets after migration\n";
        echo "  make:module <name>     Scaffold a new application module (controller + /api service + acl)\n";
        echo "  version                Show the Tiger Core version\n";
        break;
}
